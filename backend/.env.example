# Supabase project settings - Project Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only, never expose to the browser

# Groq - console.groq.com (free). Complaint triage falls back safely if unset.
GROQ_API_KEY=your-groq-api-key

# Resend - resend.com/api-keys (free, 3000 emails/month). Booking confirmations
# are skipped with a console warning if unset.
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=hostel@yourdomain.com

PORT=4000
